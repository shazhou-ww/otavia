{
  "name": "otavia-monorepo",
  "private": true,
  "description": "Otavia monorepo (workspace root)",
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --cwd packages/cli-legacy dev",
    "cli:multicloud": "bun run --cwd packages/cli dev",
    "typecheck": "bun run --cwd packages/cli-legacy typecheck",
    "test": "bun run --cwd packages/cli-legacy test",
    "build:runtime": "bun run --cwd packages/cli-legacy build:runtime",
    "smoke:init-dev": "bun run --cwd packages/cli-legacy smoke:init-dev",
    "smoke:init": "bun run packages/cli/scripts/smoke-init.mjs"
  }
}
