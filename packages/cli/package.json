{
  "name": "@otavia/cli",
  "version": "0.0.1",
  "description": "Otavia multicloud CLI (scaffold)",
  "type": "module",
  "bin": {
    "otavia": "src/cli.ts"
  },
  "exports": {
    ".": "./src/cli.ts",
    "./dev/main-frontend-runtime/main-entry": "./src/dev/main-frontend-runtime/main-entry.ts",
    "./dev/main-frontend-runtime/vite-config": "./src/dev/main-frontend-runtime/vite-config.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/"
  },
  "dependencies": {
    "@otavia/host-aws": "workspace:*",
    "@otavia/host-azure": "workspace:*",
    "@otavia/host-contract": "workspace:*",
    "@otavia/runtime-contract": "workspace:*",
    "@otavia/stack": "workspace:*",
    "@vitejs/plugin-react": "^4.3.4",
    "commander": "^12.1.0",
    "hono": "^4.6.16",
    "vite": "^6.0.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "typescript": "^5.8.3"
  }
}
