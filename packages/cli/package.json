{
  "name": "@otavia/cli",
  "version": "0.0.6",
  "description": "Otavia CLI (AWS-only)",
  "type": "module",
  "types": "./dist/cli.d.ts",
  "bin": {
    "otavia": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./dev/main-frontend-runtime/main-entry": {
      "types": "./dist/dev/main-frontend-runtime/main-entry.d.ts",
      "import": "./dist/dev/main-frontend-runtime/main-entry.js"
    },
    "./dev/main-frontend-runtime/vite-config": {
      "types": "./dist/dev/main-frontend-runtime/vite-config.d.ts",
      "import": "./dist/dev/main-frontend-runtime/vite-config.js"
    }
  },
  "files": ["dist", "src", "assets"],
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build ./src/cli.ts ./src/dev/main-frontend-runtime/main-entry.ts ./src/dev/main-frontend-runtime/vite-config.ts --outdir dist --target node --format esm --packages external",
    "build:types": "tsc -p tsconfig.build.json",
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/",
    "smoke:e2e": "bun run scripts/smoke-e2e.ts"
  },
  "dependencies": {
    "@otavia/host-aws": "^0.0.2",
    "@otavia/host-contract": "^0.0.2",
    "@otavia/stack": "^0.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "commander": "^12.1.0",
    "hono": "^4.6.16",
    "vite": "^6.0.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "typescript": "^5.8.3"
  }
}
